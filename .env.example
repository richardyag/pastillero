# Configuración de Firebase para sincronización en tiempo real
# Copiá este archivo a .env.local y completá los valores con los de tu proyecto Firebase.
# Si estas variables no están configuradas, la app funciona 100% offline sin cambios.
#
# Pasos:
# 1. Crear proyecto en https://console.firebase.google.com
# 2. Activar Firestore Database (modo producción)
# 3. Agregar una app web al proyecto y copiar los valores del config
# 4. Agregar reglas de Firestore (ver README o las instrucciones en la app)
# 5. Agregar estas variables como GitHub Secrets para el deploy automático

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
